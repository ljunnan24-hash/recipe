# 复制为 .env 或 .env.local（本地），服务器上单独建 /home/ubuntu/recipe/.env（勿提交 Git）
# 豆包（火山方舟）
DOUBAO_API_KEY=
# 可选
# DOUBAO_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/responses
# DOUBAO_MODEL=doubao-seed-2-0-mini-260215
# DOUBAO_VISION_MODEL=

# 服务端口（Nginx 反代到本端口）
SERVER_PORT=4301

# Supabase（深大食堂、成分表等；不填则相关能力降级）
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SUPABASE_TIMEOUT_MS=6000

# 生产环境建议
# NODE_ENV=production
# 经 Nginx 反代一层时建议
# TRUST_PROXY=1

# 仅当「网页域名」与「API 域名」不同源时填写，逗号分隔，须与浏览器访问来源完全一致（含 https）
# ALLOWED_ORIGINS=https://www.你的域名.com

# 生产环境默认关闭 /api/test-doubao、/api/test-supabase；临时排查可设 1
# ENABLE_DEBUG_ROUTES=0
