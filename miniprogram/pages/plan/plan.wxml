<app-header title="方案" />
<view class="container pagePad safe-area-pb">
  <view class="card">
    <view style="display:flex; align-items:center; justify-content:space-between;">
      <text class="title">方案</text>
      <text class="sectionTag">PLAN</text>
    </view>
    <text class="muted">对齐网页版：一键生成三餐，并支持换一批推荐。</text>

    <view class="divider"></view>

    <button class="btn-primary full" bindtap="onTryPlan" loading="{{loading}}">{{result ? '换一批推荐' : '生成今日方案'}}</button>
    <text class="mutedTiny" wx:if="{{loading && retryCount}}">重试中（第 {{retryCount}} 次）…</text>
    <text class="err" wx:if="{{err}}">{{err}}</text>
    <view wx:if="{{result}}" class="result">
      <view class="cover">
        <image class="coverImg" src="../../assets/meal-bg.png" mode="aspectFill" />
        <view class="coverMask"></view>
        <view class="coverText">
          <text class="coverTitle">今日推荐</text>
          <text class="coverSub">三餐一键参考 · 可换一批</text>
        </view>
      </view>
      <view class="mealCard">
        <text class="mealLabel">早餐</text>
        <text class="mealName">{{result.breakfast.name}}</text>
        <text class="mealMeta">{{result.breakfast.calories}} kcal</text>
      </view>
      <view class="mealCard">
        <text class="mealLabel">午餐</text>
        <text class="mealName">{{result.lunch.name}}</text>
        <text class="mealMeta">{{result.lunch.calories}} kcal</text>
      </view>
      <view class="mealCard">
        <text class="mealLabel">晚餐</text>
        <text class="mealName">{{result.dinner.name}}</text>
        <text class="mealMeta">{{result.dinner.calories}} kcal</text>
      </view>
    </view>
  </view>
</view>
