.full {
  width: 100%;
  margin-top: 12rpx;
}

.err {
  display: block;
  color: #dc2626;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.result {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 24rpx;
  border: 1rpx solid #f3f4f6;
}

.cover {
  position: relative;
  width: 100%;
  height: 220rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.coverImg {
  width: 100%;
  height: 100%;
}

.coverMask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0.10) 0%, rgba(0,0,0,0.55) 100%);
}

.coverText {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  color: #fff;
}

.coverTitle {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
}

.coverSub {
  display: block;
  font-size: 24rpx;
  opacity: 0.92;
  margin-top: 8rpx;
}

.mealCard {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #f3f4f6;
  margin-bottom: 14rpx;
}

.mealLabel {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.mealName {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  margin-top: 6rpx;
  color: #111827;
}

.mealMeta {
  display: block;
  font-size: 24rpx;
  color: #07c160;
  font-weight: 900;
  margin-top: 8rpx;
}
