.err {
  display: block;
  color: #dc2626;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.inputBar {
  margin-top: 0;
  padding: 24rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.input {
  flex: 1;
}

.sendBtn {
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.bubble {
  max-width: 92%;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  margin-top: 16rpx;
  white-space: pre-wrap;
  line-height: 1.6;
}

.bubbleText {
  font-size: 28rpx;
}

.bubbleModel {
  background: #f3f4f6;
  color: #111827;
  align-self: flex-start;
}

.bubbleUser {
  background: #07c160;
  color: #fff;
  margin-left: auto;
}
