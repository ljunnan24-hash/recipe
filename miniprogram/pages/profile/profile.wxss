.preview {
  display: block;
  font-size: 22rpx;
  word-break: break-all;
  margin-top: 16rpx;
}

.full {
  width: 100%;
}

.goalGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 12rpx;
}

.goalBtn {
  width: 100%;
  box-sizing: border-box;
  background: #f3f4f6;
  border-radius: 24rpx;
  height: 92rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #6b7280;
  border: none;
}

.goalBtn::after {
  border: none;
}

.goalOn {
  background: #07c160;
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.28);
}
