.full {
  width: 100%;
  margin-top: 12rpx;
}

.err {
  display: block;
  color: #dc2626;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.resultCard {
  margin-top: 22rpx;
  padding: 24rpx;
  background: #f9fafb;
