.page {
  padding-bottom: 32rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.block {
  display: block;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.full {
  width: 100%;
}

.err {
  display: block;
  color: #dc2626;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.result {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f0fdf4;
  border-radius: 16rpx;
}

.row {
  display: block;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}
