<view class="page">
  <view class="card">
    <text class="title">拍摄 / 相册</text>
    <text class="muted block">使用 wx.chooseMedia 选图 → 读 base64 → 调用 /api/ai/scan（与 H5 一致）。</text>
    <button class="btn-primary full" bindtap="onPick" loading="{{loading}}">选择图片并识别</button>
    <text class="err" wx:if="{{err}}">{{err}}</text>
    <view wx:if="{{scan}}" class="result">
      <text class="row">名称：{{scan.name}}</text>
      <text class="row">热量：{{scan.calories}} kcal</text>
      <text class="row">蛋白：{{scan.protein}} g · 碳水：{{scan.carbs}} g · 脂肪：{{scan.fat}} g</text>
      <text class="row muted" wx:if="{{scan.estimatedWeightGrams}}">估算可食部：{{scan.estimatedWeightGrams}} g</text>
    </view>
  </view>
</view>
